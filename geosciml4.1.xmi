												</UML:Comment>
												<UML:Class name="GeochronologicInterpretation" xmi.id="EAID_A1B6B909_67BC_419f_AEF9_8696BB63F29E" visibility="public" namespace="EAPK_94607C32_2900_41bb_96E6_0F49ED622F4C" isRoot="false" isLeaf="false" isAbstract="false" isActive="false">
													<UML:ModelElement.stereotype>
														<UML:Stereotype name="featureType"/>
													</UML:ModelElement.stereotype>
													<UML:ModelElement.taggedValue>
														<UML:TaggedValue tag="documentation" value="A &lt;font color=&quot;#4f81bd&quot;&gt;GeochronologicInterpretation&lt;/font&gt; is an interpretation made by a geologist of the age of a specimen made by statistical analysis of a collection of observations.  A geologic specimen may have multiple geochronological interpretations made on it, each related to a different observation/result collection.&#xA;"/>
														<UML:TaggedValue tag="isSpecification" value="false"/>
														<UML:TaggedValue tag="ea_stype" value="Class"/>
														<UML:TaggedValue tag="ea_ntype" value="0"/>
														<UML:TaggedValue tag="version" value="4.0"/>
														<UML:TaggedValue tag="package" value="EAPK_94607C32_2900_41bb_96E6_0F49ED622F4C"/>
														<UML:TaggedValue tag="date_created" value="2008-07-04 11:52:15"/>
														<UML:TaggedValue tag="date_modified" value="2016-10-01 14:27:16"/>
														<UML:TaggedValue tag="gentype" value="Java"/>
														<UML:TaggedValue tag="tagged" value="0"/>
