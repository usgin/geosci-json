												<UML:Class name="NonDirectionalStructure" xmi.id="EAID_59B32B0C_5353_42fd_9A70_4FF6C046E1BC" visibility="public" namespace="EAPK_76DD834F_0286_4ec2_BCB8_D1C402B5E22C" isRoot="false" isLeaf="false" isAbstract="false" isActive="false">
