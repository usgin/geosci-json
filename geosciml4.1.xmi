															<UML:ModelElement.taggedValue>
																<UML:TaggedValue tag="description" value="The property &lt;font color=&quot;#4f81bd&quot;&gt;size&lt;/font&gt; (&lt;font color=&quot;#4f81bd&quot;&gt;SWE::QuantityRange&lt;/font&gt;) reports the size that specifies particle grainsize.  Values may be reported using absolute measurements (e.g., range, mean, median, mode, maximum).&#xA;"/>
