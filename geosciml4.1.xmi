												<UML:TaggedValue tag="lastsavedate" value="2014-06-23 17:01:40"/>
												<UML:TaggedValue tag="version" value="4.0"/>
												<UML:TaggedValue tag="isprotected" value="0"/>
												<UML:TaggedValue tag="usedtd" value="0"/>
