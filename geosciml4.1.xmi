													</UML:ModelElement.taggedValue>
													<UML:Classifier.feature>
														<UML:Attribute name="fabricType" changeable="none" visibility="public" ownerScope="instance" targetScope="instance">
															<UML:Attribute.initialValue>
																<UML:Expression/>
