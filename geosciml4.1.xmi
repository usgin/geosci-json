														<UML:AssociationEnd visibility="public" multiplicity="0..1" name="correlatesWith" aggregation="none" isOrdered="false" targetScope="instance" changeable="none" isNavigable="true" type="EAID_625AD357_415F_4f8b_A38F_E199B49E796F">
															<UML:ModelElement.taggedValue>
																<UML:TaggedValue tag="description" value="The correlatesWith property is an association between ContactDescription and a GeochronologicBoundary describing a geochronologic (i.e., time zone) boundary that may correlate with it.  Therefore, a contact correlation with a GeochronologicBoundary SHALL ONLY be allowed when the contactType is a ChronostratigraphicBoundary."/>
