														<UML:TaggedValue tag="$ea_xref_property" value="$XREFPROP=$XID={E2B8F06E-7B24-4c8e-B5EA-D5F4681DAF97}$XID;$NAM=Stereotypes$NAM;$TYP=element property$TYP;$VIS=Public$VIS;$DES=@STEREO;Name=FeatureType;GUID={970B6446-4D5F-4391-AA67-9D257D768FDB};FQName=ISO 19100::FeatureType;@ENDSTEREO;$DES;$CLT={22F72D69-6FF6-4012-89A7-3FFAC0091563}$CLT;$ENDXREF;$XREFPROP=$XID={A294C1AA-FCA8-4cda-AB42-49F1DFE90ECD}$XID;$NAM=CustomProperties$NAM;$TYP=element property$TYP;$VIS=Public$VIS;$DES=@PROP=@NAME=isActive@ENDNAME;@TYPE=Boolean@ENDTYPE;@VALU=@ENDVALU;@PRMT=@ENDPRMT;@ENDPROP;$DES;$CLT={22F72D69-6FF6-4012-89A7-3FFAC0091563}$CLT;$ENDXREF;"/>
