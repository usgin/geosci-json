															<UML:ModelElement.stereotype>
																<UML:Stereotype name="estimatedProperty"/>
															</UML:ModelElement.stereotype>
															<UML:ModelElement.taggedValue>
																<UML:TaggedValue tag="description" value="The &lt;font color=&quot;#4f81bd&quot;&gt;interpretedAge&lt;/font&gt; property is an association between a &lt;font color=&quot;#4f81bd&quot;&gt;GeochronologicInterpretation&lt;/font&gt; and a &lt;font color=&quot;#4f81bd&quot;&gt;GeologicEvent&lt;/font&gt; that describes the dated event, process and environment.&#xA;"/>
