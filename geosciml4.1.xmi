													</UML:ModelElement.taggedValue>
												</UML:Comment>
												<UML:Comment xmi.id="EAID_8B968437_07AF_4313_B35A_A110C0DEFB93" visibility="public" namespace="EAPK_94607C32_2900_41bb_96E6_0F49ED622F4C">
													<UML:ModelElement.taggedValue>
														<UML:TaggedValue tag="documentation" value="Manually calculated by geochronologist based on a specific SamplingFeatureCollection (may include analyses of unknown and reference material)."/>
														<UML:TaggedValue tag="isSpecification" value="false"/>
														<UML:TaggedValue tag="ea_stype" value="Note"/>
