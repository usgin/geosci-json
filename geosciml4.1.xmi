												<UML:Class name="ExposureTerm" xmi.id="EAID_2BFCA087_EE57_40a5_AF50_CCF6196446B1" visibility="public" namespace="EAPK_EB2911AC_E2EF_4ba2_9E72_194A9661D815" isRoot="false" isLeaf="false" isAbstract="false" isActive="false">
