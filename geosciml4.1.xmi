												<UML:Class name="LinearDirectedCode" xmi.id="EAID_4F66BDCB_9662_4c0e_9387_1AFE7564FCA1" visibility="public" namespace="EAPK_62318703_ED17_4e6e_8328_9831DBFE0A02" isRoot="false" isLeaf="false" isAbstract="false" isActive="false">
