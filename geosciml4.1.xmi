																<UML:TaggedValue tag="sequenceNumber" value="4" xmi.id="EAID_72AC32AC_90B2_4472_B477_5EF6C1ADFFA9"/>
															</UML:ModelElement.taggedValue>
														</UML:AssociationEnd>
													</UML:Association.connection>
												</UML:Association>
												<UML:Class name="GeochronologicEra" xmi.id="EAID_87E807D4_B547_4527_95DA_3886362CC5FC" visibility="public" namespace="EAPK_914D7181_CF32_48c0_ACC1_08ED6F156D9E" isRoot="false" isLeaf="false" isAbstract="false" isActive="false">
													<UML:ModelElement.stereotype>
														<UML:Stereotype name="Type"/>
													</UML:ModelElement.stereotype>
													<UML:ModelElement.taggedValue>
														<UML:TaggedValue tag="documentation" value="A &lt;font color=&quot;#4f81bd&quot;&gt;GeochronologicEra&lt;/font&gt; is a period of time between two &lt;font color=&quot;#4f81bd&quot;&gt;GeochronologicBoundaries&lt;/font&gt;. The association of a &lt;font color=&quot;#4f81bd&quot;&gt;GeochronologicEra&lt;/font&gt; with a stratotype is optional.  In the GSSP approach recommended by ICS for the Global Geologic Timescale, Unit Stratotypes are not used.  Rather, the association of an era with geologic units and sections is indirect, via the association of an era with boundaries, which are in turn tied to stratotype points, which occur within host stratotype sections. &#xA;"/>
														<UML:TaggedValue tag="isSpecification" value="false"/>
														<UML:TaggedValue tag="ea_stype" value="Class"/>
														<UML:TaggedValue tag="ea_ntype" value="0"/>
