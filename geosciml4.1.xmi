														<UML:TaggedValue tag="$ea_xref_property" value="$XREFPROP=$XID={AD85F81C-456C-4f98-BCB5-F9D83FC98E51}$XID;$NAM=Stereotypes$NAM;$TYP=element property$TYP;$VIS=Public$VIS;$PAR=0$PAR;$DES=@STEREO;Name=CodeList;GUID={CB2FD50F-91EE-4f10-AA38-D58529B2AEC3};FQName=ISO 19100::CodeList;@ENDSTEREO;$DES;$CLT={128CFD55-27C5-45a2-9678-CA5D4F4D8595}$CLT;$ENDXREF;$XREFPROP=$XID={CFF9E6CD-C7CE-4f51-B674-7F3811402DA8}$XID;$NAM=CustomProperties$NAM;$TYP=element property$TYP;$VIS=Public$VIS;$PAR=0$PAR;$DES=@PROP=@NAME=isActive@ENDNAME;@TYPE=Boolean@ENDTYPE;@VALU=@ENDVALU;@PRMT=@ENDPRMT;@ENDPROP;$DES;$CLT={128CFD55-27C5-45a2-9678-CA5D4F4D8595}$CLT;$ENDXREF;"/>
