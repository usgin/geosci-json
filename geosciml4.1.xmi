												<UML:Comment name="Note" xmi.id="EAID_4FB956F3_7885_43d3_9035_02A518FD822C" visibility="public" namespace="EAPK_94607C32_2900_41bb_96E6_0F49ED622F4C">
													<UML:ModelElement.taggedValue>
														<UML:TaggedValue tag="documentation" value="Use a URI to name a path to a photo image of mineral grains.  Use relatedSamplingFeature to relate the photo to the sampled Specimens within it. Acquisition method = 'camera'"/>
														<UML:TaggedValue tag="isSpecification" value="false"/>
														<UML:TaggedValue tag="ea_stype" value="Note"/>
														<UML:TaggedValue tag="ea_ntype" value="0"/>
														<UML:TaggedValue tag="version" value="1.0"/>
														<UML:TaggedValue tag="isActive" value="false"/>
														<UML:TaggedValue tag="package" value="EAPK_94607C32_2900_41bb_96E6_0F49ED622F4C"/>
														<UML:TaggedValue tag="date_created" value="2008-09-08 09:43:36"/>
														<UML:TaggedValue tag="date_modified" value="2010-10-28 22:48:56"/>
														<UML:TaggedValue tag="gentype" value="&lt;none&gt;"/>
														<UML:TaggedValue tag="tagged" value="0"/>
														<UML:TaggedValue tag="package_name" value="Geochronology"/>
														<UML:TaggedValue tag="phase" value="1.0"/>
														<UML:TaggedValue tag="author" value="CGI Interoperability Working Group"/>
														<UML:TaggedValue tag="complexity" value="1"/>
