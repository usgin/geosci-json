													<UML:Classifier.feature>
														<UML:Attribute name="consolidationDegree" changeable="none" visibility="public" ownerScope="instance" targetScope="instance">
															<UML:Attribute.initialValue>
																<UML:Expression/>
															</UML:Attribute.initialValue>
															<UML:StructuralFeature.type>
																<UML:Classifier xmi.idref="EAID_A6E0AD42_2F10_40e6_8FCF_6802C6E160F6"/>
															</UML:StructuralFeature.type>
															<UML:ModelElement.stereotype>
																<UML:Stereotype name="estimatedProperty"/>
															</UML:ModelElement.stereotype>
															<UML:ModelElement.taggedValue>
																<UML:TaggedValue tag="description" value="The &lt;font color=&quot;#4f81bd&quot;&gt;consolidationDegree&lt;/font&gt; property (&lt;font color=&quot;#4f81bd&quot;&gt;SWE::Category&lt;/font&gt;) contains a term from a controlled vocabulary that specifies the degree to which an aggregation of &lt;font color=&quot;#4f81bd&quot;&gt;EarthMaterial&lt;/font&gt; particles is a distinct solid material. Consolidation and induration are related concepts specified by this property. They define a continuum from unconsolidated material to very hard rock. Induration is the degree to which a consolidated material is made hard, operationally determined by how difficult it is to break a piece of the material. Consolidated materials may have varying degrees of induration.&#xA;"/>
																<UML:TaggedValue tag="type" value="Category"/>
																<UML:TaggedValue tag="derived" value="0"/>
																<UML:TaggedValue tag="containment" value="Not Specified"/>
