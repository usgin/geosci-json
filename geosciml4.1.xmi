														<UML:Stereotype name="CodeList"/>
													</UML:ModelElement.stereotype>
													<UML:ModelElement.taggedValue>
														<UML:TaggedValue tag="documentation" value="This class is a blank placeholder for a vocabulary of terms describing the nature of the expression of the mapped feature at the earth's surface (eg, exposed, concealed)"/>
														<UML:TaggedValue tag="isSpecification" value="false"/>
														<UML:TaggedValue tag="ea_stype" value="Class"/>
