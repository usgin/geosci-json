													</UML:ModelElement.taggedValue>
												</UML:Comment>
												<UML:Comment xmi.id="EAID_7B2E0350_B2EF_4a2f_8F7E_323C10D10B57" visibility="public" namespace="EAPK_94607C32_2900_41bb_96E6_0F49ED622F4C">
													<UML:ModelElement.taggedValue>
														<UML:TaggedValue tag="documentation" value="The observed property is likely to be an isotope concentration or ratio"/>
														<UML:TaggedValue tag="isSpecification" value="false"/>
														<UML:TaggedValue tag="ea_stype" value="Note"/>
														<UML:TaggedValue tag="ea_ntype" value="0"/>
														<UML:TaggedValue tag="version" value="3.0"/>
														<UML:TaggedValue tag="isActive" value="false"/>
														<UML:TaggedValue tag="package" value="EAPK_94607C32_2900_41bb_96E6_0F49ED622F4C"/>
