											</UML:ModelElement.stereotype>
											<UML:ModelElement.taggedValue>
												<UML:TaggedValue tag="documentation" value="A &lt;font color=&quot;#4f81bd&quot;&gt;BoreholeInterval&lt;/font&gt; is similar to a &lt;font color=&quot;#4f81bd&quot;&gt;MappedFeature&lt;/font&gt;  whose shape is 1-D interval and uses the SRS of the containing borehole.  The &quot;&lt;font color=&quot;#4f81bd&quot;&gt;mappedIntervalBegin&lt;/font&gt;&quot; and &quot;&lt;font color=&quot;#4f81bd&quot;&gt;mappedIntervalEnd&lt;/font&gt;&quot; properties are alternative to the 1D geometry to overcome problems with the delivery and ease of queryability of 1D GML shapes.&#xA;"/>
												<UML:TaggedValue tag="isSpecification" value="false"/>
