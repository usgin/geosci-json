											</UML:ModelElement.stereotype>
											<UML:ModelElement.taggedValue>
												<UML:TaggedValue tag="documentation" value="The Geochronology model allows the delivery of geochronological interpretations by describing:&#xA;&lt;ol&gt;&#xA;&#x9;&lt;li&gt;a &lt;font color=&quot;#4f81bd&quot;&gt;OM::SF_Specimen&lt;/font&gt; (e.g., a rock sample)&lt;/li&gt;&#xA;&#x9;&lt;li&gt;a related collection of sampling features within that specimen (e.g., ion probe burn spots, mineral separates),&lt;/li&gt;&#xA;&#x9;&lt;li&gt;and a &lt;font color=&quot;#4f81bd&quot;&gt;GeochronologicInterpretation&lt;/font&gt; related to that sampling collection. &lt;/li&gt;&#xA;&lt;/ol&gt;&#xA;Each member of the sampling collection has a related OM_Observation/result(s).&#xA;"/>
												<UML:TaggedValue tag="parent" value="EAPK_D2459A55_0745_4570_AAFE_AE0E38D01E70"/>
												<UML:TaggedValue tag="created" value="2008-02-19 00:00:00"/>
