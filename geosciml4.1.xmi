													</UML:ModelElement.constraint>
												</UML:Class>
												<UML:Class name="StandardGlobalNumericalAge" xmi.id="EAID_E328739B_5249_49c2_B528_5C557EC6DCE8" visibility="public" namespace="EAPK_914D7181_CF32_48c0_ACC1_08ED6F156D9E" isRoot="false" isLeaf="false" isAbstract="false" isActive="false">
													<UML:ModelElement.stereotype>
														<UML:Stereotype name="Type"/>
													</UML:ModelElement.stereotype>
													<UML:ModelElement.taggedValue>
														<UML:TaggedValue tag="documentation" value="A standard numeric age point (a numeric analogue to a 'golden spike') is applicable to the formal subdivision of the Precambrian, and perhaps the Pleistocene/Holocene boundary ( &lt;a href=&quot;http://www.stratigraphy.org/index.php/ics-chart-timescale&quot;&gt;&lt;font color=&quot;#0000ff&quot;&gt;&lt;u&gt;http://www.stratigraphy.org/index.php/ics-chart-timescale&lt;/u&gt;&lt;/font&gt;&lt;/a&gt;). The boundary is not defined from a physical stratotype, although it can be influence by some, but placed at a convenient numerical value.&#xA;"/>
														<UML:TaggedValue tag="isSpecification" value="false"/>
														<UML:TaggedValue tag="ea_stype" value="Class"/>
														<UML:TaggedValue tag="ea_ntype" value="0"/>
