														<UML:TaggedValue tag="$ea_xref_property" value="$XREFPROP=$XID={804E6778-07C9-4be7-A4B2-7379B1B56015}$XID;$NAM=Stereotypes$NAM;$TYP=element property$TYP;$VIS=Public$VIS;$DES=@STEREO;Name=Type;GUID={290991D2-0B78-40f8-9C5D-527C2331ABDD};FQName=ISO 19100::Type;@ENDSTEREO;$DES;$CLT={D6017700-B8AA-4d44-96A0-819920B6290E}$CLT;$ENDXREF;$XREFPROP=$XID={C6A555CE-291A-48f3-85E9-62BC6590543D}$XID;$NAM=CustomProperties$NAM;$TYP=element property$TYP;$VIS=Public$VIS;$DES=@PROP=@NAME=isActive@ENDNAME;@TYPE=Boolean@ENDTYPE;@VALU=@ENDVALU;@PRMT=@ENDPRMT;@ENDPROP;$DES;$CLT={D6017700-B8AA-4d44-96A0-819920B6290E}$CLT;$ENDXREF;"/>
