															<UML:Attribute.initialValue>
																<UML:Expression body="typicalNorm"/>
															</UML:Attribute.initialValue>
															<UML:StructuralFeature.type>
																<UML:Classifier xmi.idref="EAID_19266681_45DA_43b8_992C_663353B498A2"/>
															</UML:StructuralFeature.type>
															<UML:ModelElement.stereotype>
																<UML:Stereotype name="voidable"/>
															</UML:ModelElement.stereotype>
															<UML:ModelElement.taggedValue>
																<UML:TaggedValue tag="description" value="The property &lt;font color=&quot;#4f81bd&quot;&gt;purpose:DescriptionPurpose&lt;/font&gt; specifies the intended purpose/level of abstraction for a given feature or object instance.  The possible values are: &lt;b&gt;instance&lt;/b&gt;, &lt;b&gt;typicalNorm&lt;/b&gt;, and &lt;b&gt;definingNorm&lt;/b&gt;.&#xA;"/>
																<UML:TaggedValue tag="type" value="DescriptionPurpose"/>
