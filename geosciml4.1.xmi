												<UML:Class name="Foliation" xmi.id="EAID_22F72D69_6FF6_4012_89A7_3FFAC0091563" visibility="public" namespace="EAPK_386E9010_25AA_49b9_9032_049D332BBBED" isRoot="false" isLeaf="false" isAbstract="false" isActive="false">
													<UML:ModelElement.stereotype>
														<UML:Stereotype name="FeatureType"/>
													</UML:ModelElement.stereotype>
													<UML:ModelElement.taggedValue>
														<UML:TaggedValue tag="documentation" value="A foliation is a planar arrangement of textural or structural features in any type of rock.  It includes any of a wide variety of penetrative planar geological structures that may be present in a rock.  Examples include schistosity, mylonitic foliation, penetrative bedding structure (lamination), and cleavage.  Following the proposed definition of gneiss by the NADM Science Language Technical Team, penetrative planar foliation defined by layers &amp;gt; 5 mm thick is considered &lt;font color=&quot;#4f81bd&quot;&gt;Layering&lt;/font&gt;. &#xA;"/>
														<UML:TaggedValue tag="isSpecification" value="false"/>
														<UML:TaggedValue tag="ea_stype" value="Class"/>
														<UML:TaggedValue tag="ea_ntype" value="0"/>
														<UML:TaggedValue tag="version" value="4.0"/>
														<UML:TaggedValue tag="package" value="EAPK_386E9010_25AA_49b9_9032_049D332BBBED"/>
