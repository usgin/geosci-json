													</UML:ModelElement.taggedValue>
												</UML:Comment>
												<UML:Class name="MaterialRelation" xmi.id="EAID_C0695B09_DC02_4bdd_AE59_38E8AE1F4632" visibility="public" namespace="EAPK_0D03BE5C_ED18_46e5_99E3_1897090F2BAA" isRoot="false" isLeaf="false" isAbstract="false" isActive="false">
													<UML:ModelElement.stereotype>
														<UML:Stereotype name="type"/>
													</UML:ModelElement.stereotype>
													<UML:ModelElement.taggedValue>
														<UML:TaggedValue tag="documentation" value="The &lt;font color=&quot;#4f81bd&quot;&gt;MaterialRelation&lt;/font&gt; class describes the relationships between constituent parts in an &lt;font color=&quot;#4f81bd&quot;&gt;EarthMaterial&lt;/font&gt; (e.g. A mineral overgrowth on a phenocryst within a granite).  &#xA;Example:  Consider an overgrowth of albite on plagioclase in a granite. The Source would originate with the albite constituentPart description.  In this case, the Target would point to the plagioclase &lt;font color=&quot;#4f81bd&quot;&gt;constituentPart&lt;/font&gt; description and the relationship attribute would be 'overgrowth' and the &lt;font color=&quot;#4f81bd&quot;&gt;sourceRole&lt;/font&gt; is 'overgrows'.  Other appropriate role attributes might include: crosscuts, replaces, etc. for crosscutting and replacement relationships.  Inverse relationships must be explicitly recorded.&#xA;"/>
														<UML:TaggedValue tag="isSpecification" value="false"/>
														<UML:TaggedValue tag="ea_stype" value="Class"/>
														<UML:TaggedValue tag="ea_ntype" value="0"/>
														<UML:TaggedValue tag="version" value="4.0"/>
														<UML:TaggedValue tag="package" value="EAPK_0D03BE5C_ED18_46e5_99E3_1897090F2BAA"/>
