																<UML:TaggedValue tag="ea_guid" value="{13EF909A-AB70-4901-8CA1-C3BA3F992378}"/>
																<UML:TaggedValue tag="ea_localid" value="1577"/>
																<UML:TaggedValue tag="styleex" value="volatile=0;IsLiteral=0;"/>
																<UML:TaggedValue tag="$ea_xref_property" value="$XREFPROP=$XID={A189651B-3DD6-482f-8860-113E68B689AF}$XID;$NAM=CustomProperties$NAM;$TYP=attribute property$TYP;$VIS=Public$VIS;$PAR=0$PAR;$DES=@PROP=@NAME=isID@ENDNAME;@TYPE=Boolean@ENDTYPE;@VALU=0@ENDVALU;@PRMT=@ENDPRMT;@ENDPROP;$DES;$CLT={13EF909A-AB70-4901-8CA1-C3BA3F992378}$CLT;$SUP=&lt;none&gt;$SUP;$ENDXREF;$XREFPROP=$XID={C8210B6B-3E23-4c60-8D8B-D13BCD7E3949}$XID;$NAM=Stereotypes$NAM;$TYP=attribute property$TYP;$VIS=Public$VIS;$DES=@STEREO;Name=estimatedProperty;GUID={D01C1106-4585-48f6-BE27-902A1F555F99};@ENDSTEREO;@STEREO;Name=voidable;GUID={8E0E89B6-F7AD-446e-824C-62178F8077A0};@ENDSTEREO;$DES;$CLT={13EF909A-AB70-4901-8CA1-C3BA3F992378}$CLT;$ENDXREF;"/>
