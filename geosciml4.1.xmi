												<UML:Class name="Fracture" xmi.id="EAID_59E4D654_B8AE_4ce6_95C7_C61A12CBB143" visibility="public" namespace="EAPK_76DD834F_0286_4ec2_BCB8_D1C402B5E22C" isRoot="false" isLeaf="false" isAbstract="true" isActive="false">
													<UML:ModelElement.stereotype>
														<UML:Stereotype name="FeatureType"/>
													</UML:ModelElement.stereotype>
													<UML:ModelElement.taggedValue>
														<UML:TaggedValue tag="documentation" value="Fractures are cracks in the earth surface. If there is no displacement it is a joint. If there is displacement and you are in the brittle zone it is a fault. In the ductile zone, a fracture with displacement with fracture is called a shear.  FaultSurface as a separate class is not considered necessary for GeoSciML 2.&#xA;Recording observations on FaultSurface should be in observation and measurement. The observation needs to be able to distinguish the type of measurement made (PropertyType)&#xA;"/>
														<UML:TaggedValue tag="isSpecification" value="false"/>
														<UML:TaggedValue tag="ea_stype" value="Class"/>
														<UML:TaggedValue tag="ea_ntype" value="0"/>
														<UML:TaggedValue tag="version" value="4.0"/>
														<UML:TaggedValue tag="package" value="EAPK_76DD834F_0286_4ec2_BCB8_D1C402B5E22C"/>
														<UML:TaggedValue tag="date_created" value="2004-05-13 15:15:44"/>
														<UML:TaggedValue tag="date_modified" value="2015-07-09 23:31:01"/>
														<UML:TaggedValue tag="gentype" value="Java"/>
														<UML:TaggedValue tag="tagged" value="0"/>
