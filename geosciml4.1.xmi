												<UML:Comment xmi.id="EAID_7D6C3AFA_0EC1_4189_855B_234663AE4A4E" visibility="public" namespace="EAPK_682C8311_61B9_4850_8625_FB36808A3148">
													<UML:ModelElement.taggedValue>
														<UML:TaggedValue tag="documentation" value="More restricted collection types are likely to be useful in various situations. For now GSML is left as the only explicit collection with the intention that it will be constrained by service profiles for particular use cases. In the future, practice should indicate what other explicit collections should be included."/>
