										<UML:Class name="BoreholeInterval" xmi.id="EAID_73DD4A6D_1BCE_421f_B6B6_00A34E56B7BC" visibility="public" namespace="EAPK_93D78B7F_AC42_4588_B336_E5752E78AE36" isRoot="false" isLeaf="false" isAbstract="false" isActive="false">
