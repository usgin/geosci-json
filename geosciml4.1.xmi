												<UML:Class name="CompoundMaterial" xmi.id="EAID_22E867E8_8834_46e1_8B73_72F71FE72495" visibility="public" namespace="EAPK_EB2911AC_E2EF_4ba2_9E72_194A9661D815" isRoot="false" isLeaf="false" isAbstract="true" isActive="false">
													<UML:ModelElement.stereotype>
														<UML:Stereotype name="type"/>
													</UML:ModelElement.stereotype>
													<UML:ModelElement.taggedValue>
														<UML:TaggedValue tag="documentation" value="A &lt;font color=&quot;#4f81bd&quot;&gt;CompoundMaterial&lt;/font&gt; is an &lt;font color=&quot;#4f81bd&quot;&gt;EarthMaterial&lt;/font&gt; composed of particles made of &lt;font color=&quot;#4f81bd&quot;&gt;EarthMaterials&lt;/font&gt;, possibly including other &lt;font color=&quot;#4f81bd&quot;&gt;CompoundMaterials&lt;/font&gt;.  This class is provided primarily as an extensibility point for related domain models that wish to import and build on GeoSciML, and wish to define material types that are compound but are not rock or rock-like material. In the context of GeoSciML &quot;&lt;font color=&quot;#4f81bd&quot;&gt;RockMaterial&lt;/font&gt;&quot; should be used to describe units made of rock.  &#xA;"/>
														<UML:TaggedValue tag="isSpecification" value="false"/>
														<UML:TaggedValue tag="ea_stype" value="Class"/>
														<UML:TaggedValue tag="ea_ntype" value="0"/>
