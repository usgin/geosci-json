													<UML:ModelElement.taggedValue>
														<UML:TaggedValue tag="documentation" value="A GeoSciML collection is a convenience class to manage sets of features or type instances.  A collection contains classes that facilitate the structuring of WFS response documents and other application uses.   &#xA;"/>
