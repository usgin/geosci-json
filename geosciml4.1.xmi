														<UML:TaggedValue tag="$ea_xref_property" value="$XREFPROP=$XID={C8453A79-4202-497e-9C42-A08D27F860BC}$XID;$NAM=Stereotypes$NAM;$TYP=element property$TYP;$VIS=Public$VIS;$DES=@STEREO;Name=Type;GUID={290991D2-0B78-40f8-9C5D-527C2331ABDD};FQName=ISO 19100::Type;@ENDSTEREO;$DES;$CLT={E328739B-5249-49c2-B528-5C557EC6DCE8}$CLT;$ENDXREF;$XREFPROP=$XID={2B2F33A3-7CF4-46e2-9369-FE8C3372616B}$XID;$NAM=CustomProperties$NAM;$TYP=element property$TYP;$VIS=Public$VIS;$DES=@PROP=@NAME=isActive@ENDNAME;@TYPE=Boolean@ENDTYPE;@VALU=@ENDVALU;@PRMT=@ENDPRMT;@ENDPROP;$DES;$CLT={E328739B-5249-49c2-B528-5C557EC6DCE8}$CLT;$ENDXREF;"/>
