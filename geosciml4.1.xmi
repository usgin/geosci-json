												<UML:Class name="ConventionCode" xmi.id="EAID_C37C61B1_3BD6_46c8_8D61_5B29CC1F3955" visibility="public" namespace="EAPK_62318703_ED17_4e6e_8328_9831DBFE0A02" isRoot="false" isLeaf="false" isAbstract="false" isActive="false">
