															<UML:ModelElement.stereotype>
																<UML:Stereotype name="estimatedProperty"/>
															</UML:ModelElement.stereotype>
															<UML:ModelElement.taggedValue>
																<UML:TaggedValue tag="description" value="The &lt;font color=&quot;#4f81bd&quot;&gt;color&lt;/font&gt; property (&lt;font color=&quot;#4f81bd&quot;&gt;SWE::Category&lt;/font&gt;) is a term from a controlled vocabulary that specifies the colour of the earth material. Color schemes such as the Munsell rock and soil color schemes may be used.&#xA;"/>
																<UML:TaggedValue tag="type" value="Category"/>
																<UML:TaggedValue tag="derived" value="0"/>
