												<UML:Class name="PhysicalDescription" xmi.id="EAID_DF21AB41_C085_4ac9_B6F6_DFFDFCF925FF" visibility="public" namespace="EAPK_919F2A42_F899_4b86_9B24_56636A2F6049" isRoot="false" isLeaf="false" isAbstract="false" isActive="false">
