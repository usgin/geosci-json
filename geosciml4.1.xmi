												<UML:Comment xmi.id="EAID_3CE11DEC_F7F5_4082_8B92_DB2810329339" visibility="public" namespace="EAPK_EB2911AC_E2EF_4ba2_9E72_194A9661D815">
													<UML:ModelElement.taggedValue>
														<UML:TaggedValue tag="documentation" value="&lt;font color=&quot;#c0c0c0&quot;&gt;For basic profile, would probably want to prescribe the occurrence relation from feature to mapped feature. This greatly simplifies logic required in client. Specification is either inline or by reference.&lt;/font&gt;&#xA;&lt;font color=&quot;#c0c0c0&quot;&gt;&#xA;&lt;/font&gt;&lt;font color=&quot;#c0c0c0&quot;&gt;Decision: Services of geologic units and events that don't have spatial representations (eg, stratigraphic lexicons) have no occurrences associated with the GeologicFeatures (update 2014-06-30 Tucson F2F). Must maintain 0..* cardinality.&lt;/font&gt;"/>
														<UML:TaggedValue tag="isSpecification" value="false"/>
														<UML:TaggedValue tag="ea_stype" value="Note"/>
														<UML:TaggedValue tag="ea_ntype" value="0"/>
