												</UML:Comment>
												<UML:Class name="ReferenceSpecimen" xmi.id="EAID_A953E1E0_629C_4e85_A72E_737CDDDCFAE9" visibility="public" namespace="EAPK_23107128_C0E4_4f44_BA19_7C0926853370" isRoot="false" isLeaf="false" isAbstract="false" isActive="false">
													<UML:ModelElement.stereotype>
														<UML:Stereotype name="featureType"/>
													</UML:ModelElement.stereotype>
													<UML:ModelElement.taggedValue>
														<UML:TaggedValue tag="documentation" value="A reference specimen is a specimen with known or accepted values of some property.  The citation property describes the location of a published description of these values. Reference specimens include analytical blanks. &lt;font color=&quot;#4f81bd&quot;&gt;ReferenceSpecimens&lt;/font&gt; are used in quality control procedures to assess method reproducibility. &#xA;&#xA;Analytical results from a reference specimen analysed during an &lt;font color=&quot;#4f81bd&quot;&gt;AnalyticalSession&lt;/font&gt; are delivered in the same way as the results of other specimens analysed in that session.&#xA;&#xA;"/>
														<UML:TaggedValue tag="isSpecification" value="false"/>
