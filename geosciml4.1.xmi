															</UML:ModelElement.taggedValue>
														</UML:Attribute>
														<UML:Attribute name="shape" changeable="none" visibility="public" ownerScope="instance" targetScope="instance">
															<UML:Attribute.initialValue>
																<UML:Expression/>
															</UML:Attribute.initialValue>
															<UML:StructuralFeature.type>
																<UML:Classifier xmi.idref="EAID_A6E0AD42_2F10_40e6_8FCF_6802C6E160F6"/>
															</UML:StructuralFeature.type>
															<UML:ModelElement.stereotype>
																<UML:Stereotype name="estimatedProperty"/>
															</UML:ModelElement.stereotype>
															<UML:ModelElement.taggedValue>
																<UML:TaggedValue tag="description" value="The &lt;font color=&quot;#4f81bd&quot;&gt;shape&lt;/font&gt; property (&lt;font color=&quot;#4f81bd&quot;&gt;SWE::Category&lt;/font&gt;) describes, &#xA;&lt;ul&gt;&#xA;&#x9;&lt;li&gt;the development of crystal faces bounding particles in crystalline compound materials, and &lt;/li&gt;&#xA;&#x9;&lt;li&gt;the surface rounding of grains in sedimentary rocks.&lt;/li&gt;&#xA;&lt;/ul&gt;&#xA;&#xA; Roundness is a measure of the sharpness of the edges between surfaces bounding a particle&#xA;&#xA;The terms shall be a term from a controlled vocabulary and be appropriate for the kind of compound material (e.g., for crystalline rocks- euhedral, ideoblastic, subhedral, anhedral, xenoblastic; for sedimentary rocks - angular, rounded).&#xA;"/>
																<UML:TaggedValue tag="type" value="Category"/>
																<UML:TaggedValue tag="derived" value="0"/>
																<UML:TaggedValue tag="containment" value="Not Specified"/>
																<UML:TaggedValue tag="length" value="0"/>
																<UML:TaggedValue tag="ordered" value="0"/>
