												<UML:Class name="GSML_LinearOrientation" xmi.id="EAID_C0A3056D_FA18_4027_BE04_0AFA3C2B5BD7" visibility="public" namespace="EAPK_62318703_ED17_4e6e_8328_9831DBFE0A02" isRoot="false" isLeaf="false" isAbstract="false" isActive="false">
													<UML:ModelElement.stereotype>
														<UML:Stereotype name="DataType"/>
													</UML:ModelElement.stereotype>
													<UML:ModelElement.taggedValue>
														<UML:TaggedValue tag="documentation" value="A linear orientation is composed of a trend (the compass orientation of the line) and a plunge (the angle from the horizontal).  This vector may be oriented (pointing in a specific direction) or not. &#xA;"/>
														<UML:TaggedValue tag="isSpecification" value="false"/>
														<UML:TaggedValue tag="ea_stype" value="Class"/>
														<UML:TaggedValue tag="ea_ntype" value="0"/>
