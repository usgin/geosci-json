												<UML:Class name="LithologyTerm" xmi.id="EAID_DF881804_4B5B_457e_B976_3E33A6F843F5" visibility="public" namespace="EAPK_EB2911AC_E2EF_4ba2_9E72_194A9661D815" isRoot="false" isLeaf="false" isAbstract="false" isActive="false">
