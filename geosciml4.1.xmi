														<UML:TaggedValue tag="$ea_xref_property" value="$XREFPROP=$XID={5A3A272E-45FA-45ee-AD19-BE47A55808FB}$XID;$NAM=Stereotypes$NAM;$TYP=element property$TYP;$VIS=Public$VIS;$DES=@STEREO;Name=FeatureType;GUID={970B6446-4D5F-4391-AA67-9D257D768FDB};FQName=ISO 19100::FeatureType;@ENDSTEREO;$DES;$CLT={6A81087A-0778-4235-8F6A-3CADBB0E9016}$CLT;$ENDXREF;$XREFPROP=$XID={05649106-F9ED-4b28-8B38-5F0FBA87D451}$XID;$NAM=CustomProperties$NAM;$TYP=element property$TYP;$VIS=Public$VIS;$DES=@PROP=@NAME=isActive@ENDNAME;@TYPE=Boolean@ENDTYPE;@VALU=@ENDVALU;@PRMT=@ENDPRMT;@ENDPROP;$DES;$CLT={6A81087A-0778-4235-8F6A-3CADBB0E9016}$CLT;$ENDXREF;"/>
													</UML:ModelElement.taggedValue>
													<UML:Classifier.feature>
														<UML:Attribute name="observationMethod" changeable="none" visibility="public" ownerScope="instance" targetScope="instance">
															<UML:Attribute.initialValue>
																<UML:Expression/>
															</UML:Attribute.initialValue>
															<UML:StructuralFeature.type>
																<UML:Classifier xmi.idref="EAID_A6E0AD42_2F10_40e6_8FCF_6802C6E160F6"/>
															</UML:StructuralFeature.type>
															<UML:ModelElement.stereotype>
																<UML:Stereotype name="voidable"/>
															</UML:ModelElement.stereotype>
															<UML:ModelElement.taggedValue>
																<UML:TaggedValue tag="description" value="The &lt;font color=&quot;#4f81bd&quot;&gt;GeologicFeature&lt;/font&gt; observationMethod (&lt;font color=&quot;#4f81bd&quot;&gt;SWE::Category&lt;/font&gt;) specifies the approach to acquiring the collection of attribute values that constitute an individual feature instance (e.g. point count, brunton compass on site, air photo interpretation, field observation, hand specimen, laboratory, aerial photography, creative imagination). &#xA;&lt;font color=&quot;#4f81bd&quot;&gt;ObservationMethod&lt;/font&gt; is a convenience property that provides a simple approach to observation metadata when data are reported using a feature view (as opposed to observation view).  This property corresponds (loosely) to ISO19115 Lineage. &#xA;"/>
																<UML:TaggedValue tag="type" value="Category"/>
																<UML:TaggedValue tag="derived" value="0"/>
