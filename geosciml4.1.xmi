																<UML:Expression/>
															</UML:Attribute.initialValue>
															<UML:StructuralFeature.type>
																<UML:Classifier xmi.idref="EAID_0C5875A9_6DF7_4e98_A0C3_D49CB408EAB5"/>
															</UML:StructuralFeature.type>
															<UML:ModelElement.stereotype>
																<UML:Stereotype name="voidable"/>
															</UML:ModelElement.stereotype>
															<UML:ModelElement.taggedValue>
																<UML:TaggedValue tag="description" value="The property &lt;font color=&quot;#4f81bd&quot;&gt;profileType:FoldProfileTypeTerm&lt;/font&gt; contains a term from a controlled vocabulary specifying the concave/convex geometry of fold relative to earth surface, and relationship to younging direction in folded strata if known. (e.g., antiform, synform, neutral, anticline, syncline, monocline, ptygmatic).&#xA;"/>
																<UML:TaggedValue tag="type" value="FoldProfileTypeTerm"/>
