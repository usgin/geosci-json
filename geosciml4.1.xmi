												<UML:Comment xmi.id="EAID_E96F0CA8_47E2_4fa7_82F8_9EF338079C85" visibility="public" namespace="EAPK_EB2911AC_E2EF_4ba2_9E72_194A9661D815">
													<UML:ModelElement.taggedValue>
														<UML:TaggedValue tag="documentation" value="Do we need to be able to associate relationship types, or sequence properties with the binding between an event and a feature; &#xA;Are there other properties on the GeologicEvents that are intrinsic to the event in the context of a particular geologicFeature? &#xA;Are there important use cases for a history object as a collection of ordered events that is independent of any particular feature? E.g. reuse the same history for multiple features, representation of some particular composite event.&#xA;&#xA;Decision: not in Basic.  Somebody's got to make a case and propose a solution for extended."/>
														<UML:TaggedValue tag="isSpecification" value="false"/>
														<UML:TaggedValue tag="ea_stype" value="Note"/>
														<UML:TaggedValue tag="ea_ntype" value="0"/>
														<UML:TaggedValue tag="version" value="1.0"/>
