										<UML:Class name="BoreholeInclinationCode" xmi.id="EAID_DB5643C0_8BD4_40be_A001_1FBD63ABCC76" visibility="public" namespace="EAPK_93D78B7F_AC42_4588_B336_E5752E78AE36" isRoot="false" isLeaf="false" isAbstract="false" isActive="false">
