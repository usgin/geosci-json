													<UML:ModelElement.taggedValue>
														<UML:TaggedValue tag="documentation" value="This class is an empty placeholder for a vocabulary of terms describing the method used to determine the measured orientation. Users are encouraged to use a vocabulary of terms managed by the CGI vocabularies working group outside of this model.  "/>
