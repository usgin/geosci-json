																<UML:TaggedValue tag="ea_guid" value="{0ACE92C1-088C-42cf-93C8-D003E3CC8FC3}"/>
																<UML:TaggedValue tag="ea_localid" value="1563"/>
																<UML:TaggedValue tag="styleex" value="volatile=0;IsLiteral=0;"/>
																<UML:TaggedValue tag="$ea_xref_property" value="$XREFPROP=$XID={D9DD235A-FCBB-4119-BB1D-0BF6F485A052}$XID;$NAM=CustomProperties$NAM;$TYP=attribute property$TYP;$VIS=Public$VIS;$PAR=0$PAR;$DES=@PROP=@NAME=isID@ENDNAME;@TYPE=Boolean@ENDTYPE;@VALU=0@ENDVALU;@PRMT=@ENDPRMT;@ENDPROP;$DES;$CLT={0ACE92C1-088C-42cf-93C8-D003E3CC8FC3}$CLT;$SUP=&lt;none&gt;$SUP;$ENDXREF;$XREFPROP=$XID={D2428931-2F49-4250-A508-26C910438781}$XID;$NAM=Stereotypes$NAM;$TYP=attribute property$TYP;$VIS=Public$VIS;$DES=@STEREO;Name=estimatedProperty;GUID={D01C1106-4585-48f6-BE27-902A1F555F99};@ENDSTEREO;@STEREO;Name=voidable;GUID={2CBFCB76-8594-45ef-BBE9-5F19B11DB530};@ENDSTEREO;$DES;$CLT={0ACE92C1-088C-42cf-93C8-D003E3CC8FC3}$CLT;$ENDXREF;"/>
