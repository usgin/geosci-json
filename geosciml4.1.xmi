												<UML:Class name="GSML_PlanarOrientation" xmi.id="EAID_46259D53_650A_4603_A643_14762C4B9DC8" visibility="public" namespace="EAPK_62318703_ED17_4e6e_8328_9831DBFE0A02" isRoot="false" isLeaf="false" isAbstract="false" isActive="false">
													<UML:ModelElement.stereotype>
														<UML:Stereotype name="DataType"/>
													</UML:ModelElement.stereotype>
													<UML:ModelElement.taggedValue>
														<UML:TaggedValue tag="documentation" value="A planar orientation is composed of two values; the azimuth (a compass point) and a dip (the angle from the horizontal). Polarity of the plane indicates whether the planar orientation is associated with a directed feature that is overturned, upright, vertical, etc.  There are several conventions to encode a planar orientation and this specification does not impose one but provides a &lt;font color=&quot;#4f81bd&quot;&gt;convention&lt;/font&gt; property to report it. It must be noted that allowance for different conventions makes manipulation of the data more difficult. Therefore it is recommended that user communities adopt a single measurement convention.&#xA;"/>
														<UML:TaggedValue tag="isSpecification" value="false"/>
														<UML:TaggedValue tag="ea_stype" value="Class"/>
														<UML:TaggedValue tag="ea_ntype" value="0"/>
														<UML:TaggedValue tag="version" value="4.0"/>
