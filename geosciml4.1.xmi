												<UML:TaggedValue tag="$ea_xref_property" value="$XREFPROP=$XID={5C57A650-5A8F-4cd6-B0A5-C47F98EF24DC}$XID;$NAM=Stereotypes$NAM;$TYP=element property$TYP;$VIS=Public$VIS;$PAR=0$PAR;$DES=@STEREO;Name=FeatureType;GUID={328AFF89-983C-4732-B768-B801B367A8DE};FQName=ISO 19100::FeatureType;@ENDSTEREO;$DES;$CLT={A518DA4F-2CA4-4758-BC7A-4790DC092913}$CLT;$SUP=&lt;none&gt;$SUP;$ENDXREF;"/>
