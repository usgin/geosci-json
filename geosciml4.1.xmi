												<UML:Comment xmi.id="EAID_6B55E757_81F2_4f8d_864C_688E31B75D2A" visibility="public" namespace="EAPK_0D03BE5C_ED18_46e5_99E3_1897090F2BAA">
													<UML:ModelElement.taggedValue>
														<UML:TaggedValue tag="documentation" value="Tucson 2014 decisions:&#xA;&#xA;Discussion - Remove GeologicHistory class from GeologicRelation? (see notes in GeologyBasic diagram about unnecessary complexity of the geological history model).&#xA;Would it be easier to maintain a defined vocabulary of GeologicRelationTerm values rather than have any GeologicFeatureRelation subtypes? - OLR&#xA;&#xA;Decision - remove all Relation subtypes and use soft typing; Schematron validation of source and target classes can still be constructed based on relationshipTypeTerm values. (DONE)"/>
														<UML:TaggedValue tag="isSpecification" value="false"/>
														<UML:TaggedValue tag="ea_stype" value="Note"/>
														<UML:TaggedValue tag="ea_ntype" value="0"/>
														<UML:TaggedValue tag="version" value="1.0"/>
														<UML:TaggedValue tag="isActive" value="false"/>
														<UML:TaggedValue tag="package" value="EAPK_0D03BE5C_ED18_46e5_99E3_1897090F2BAA"/>
														<UML:TaggedValue tag="date_created" value="2014-05-14 14:34:29"/>
														<UML:TaggedValue tag="date_modified" value="2015-09-03 11:07:15"/>
														<UML:TaggedValue tag="gentype" value="&lt;none&gt;"/>
														<UML:TaggedValue tag="tagged" value="0"/>
