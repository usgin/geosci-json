															<UML:ModelElement.stereotype>
																<UML:Stereotype name="estimatedProperty"/>
															</UML:ModelElement.stereotype>
															<UML:ModelElement.taggedValue>
																<UML:TaggedValue tag="description" value="The &lt;font color=&quot;#4f81bd&quot;&gt;proportion&lt;/font&gt; property (&lt;font color=&quot;#4f81bd&quot;&gt;SWE::QuantityRange&lt;/font&gt;) reports the fraction of the whole that is formed by a ConstituentPart in a part/whole relationship.  It is used for the &lt;font color=&quot;#4f81bd&quot;&gt;ConstituentPart&lt;/font&gt; portion in a &lt;font color=&quot;#4f81bd&quot;&gt;CompoundMaterial&lt;/font&gt;.  It specifies the fraction of the &lt;font color=&quot;#4f81bd&quot;&gt;EarthMaterial&lt;/font&gt; formed by the part (e.g., 20%, minor, dominant).&#xA;"/>
																<UML:TaggedValue tag="type" value="QuantityRange"/>
