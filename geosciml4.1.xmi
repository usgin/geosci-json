														<UML:TaggedValue tag="style" value="BackColor=-1;BorderColor=-1;BorderWidth=-1;FontColor=-1;VSwimLanes=1;HSwimLanes=1;BorderStyle=0;"/>
														<UML:TaggedValue tag="$ea_xref_property" value="$XREFPROP=$XID={ED058531-1F34-42f2-8C3D-EC7A6C8B19A7}$XID;$NAM=Stereotypes$NAM;$TYP=element property$TYP;$VIS=Public$VIS;$PAR=0$PAR;$DES=@STEREO;Name=featureType;GUID={5DA0A729-23F6-4149-8C73-28D2C1BFC626};FQName=UML Profile for INSPIRE data specifications::featureType;@ENDSTEREO;$DES;$CLT={A1B6B909-67BC-419f-AEF9-8696BB63F29E}$CLT;$SUP=&lt;none&gt;$SUP;$ENDXREF;"/>
