											</UML:ModelElement.taggedValue>
										</UML:Comment>
										<UML:Comment name="Note" xmi.id="EAID_5074C333_F5F8_4771_B177_38BC0BEE662C" visibility="public" namespace="EAPK_93D78B7F_AC42_4588_B336_E5752E78AE36">
											<UML:ModelElement.taggedValue>
												<UML:TaggedValue tag="documentation" value="In the context of GeoSciML, this will typically be a GeologicFeature, such as a geologic unit. If the SamplingFeature samples multiple features (e.g. borehole, traverse) &#xA;(i) if it is a sequence of units, then the part/GeologicUnitPart mechanisms may be used, &#xA;(ii) else if it is an informal collection that exists only because of the sampling, then multiple sampledFeature roles should be used&#xA;"/>
												<UML:TaggedValue tag="isSpecification" value="false"/>
												<UML:TaggedValue tag="ea_stype" value="Note"/>
												<UML:TaggedValue tag="ea_ntype" value="0"/>
												<UML:TaggedValue tag="version" value="1.0"/>
												<UML:TaggedValue tag="isActive" value="false"/>
												<UML:TaggedValue tag="package" value="EAPK_93D78B7F_AC42_4588_B336_E5752E78AE36"/>
