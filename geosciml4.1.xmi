												</UML:Class>
												<UML:Class name="ConstituentPart" xmi.id="EAID_D2385579_8CEC_41fc_ACD0_1242C0AEF96E" visibility="public" namespace="EAPK_919F2A42_F899_4b86_9B24_56636A2F6049" isRoot="false" isLeaf="false" isAbstract="false" isActive="false">
													<UML:ModelElement.stereotype>
														<UML:Stereotype name="Type"/>
													</UML:ModelElement.stereotype>
													<UML:ModelElement.taggedValue>
														<UML:TaggedValue tag="documentation" value="The &lt;font color=&quot;#4f81bd&quot;&gt;ConstituentPart&lt;/font&gt; class describes how Earth materials may be made up of other Earth materials, including the proportion of the constituent part in the whole (e.g., 20%, minor, dominant); and the role that the constituent plays in the whole (e.g., matrix, groundmass, framework, phenocryst, xenolith, vein). &#xA;"/>
														<UML:TaggedValue tag="isSpecification" value="false"/>
														<UML:TaggedValue tag="ea_stype" value="Class"/>
