							<UML:Namespace.ownedElement>
								<UML:Collaboration xmi.id="EAID_23BB8567_B2F9_4bf2_99A5_D669389AB74A_Collaboration" name="Collaborations">
									<UML:Namespace.ownedElement>
										<UML:ClassifierRole name="GeoSciMLExtension" xmi.id="EAID_6251FE1E_5891_4aae_A3E6_8E9FB1A281B0" visibility="public" base="EAID_11111111_5487_4080_A7F4_41526CB0AA00">
											<UML:ModelElement.stereotype>
												<UML:Stereotype name="Application Schema"/>
											</UML:ModelElement.stereotype>
											<UML:ModelElement.taggedValue>
												<UML:TaggedValue tag="documentation" value="The extension package provides classes to further the descriptions of basic classes by adding more properties and supplemental relations.  It extends abstract description stubs declared in basic package and introduces new &lt;font color=&quot;#4f81bd&quot;&gt;GeologicStructure&lt;/font&gt; features.&#xA;"/>
												<UML:TaggedValue tag="isAbstract" value="false"/>
												<UML:TaggedValue tag="isSpecification" value="false"/>
												<UML:TaggedValue tag="ea_stype" value="Package"/>
												<UML:TaggedValue tag="ea_ntype" value="0"/>
												<UML:TaggedValue tag="version" value="4.0"/>
												<UML:TaggedValue tag="isActive" value="false"/>
												<UML:TaggedValue tag="package" value="EAPK_23BB8567_B2F9_4bf2_99A5_D669389AB74A"/>
												<UML:TaggedValue tag="date_created" value="2014-03-19 19:54:50"/>
												<UML:TaggedValue tag="date_modified" value="2017-01-26 09:00:02"/>
												<UML:TaggedValue tag="gentype" value="Java"/>
												<UML:TaggedValue tag="tagged" value="0"/>
												<UML:TaggedValue tag="package2" value="EAID_6251FE1E_5891_4aae_A3E6_8E9FB1A281B0"/>
												<UML:TaggedValue tag="package_name" value="GeoSciML4.1"/>
												<UML:TaggedValue tag="phase" value="1.0"/>
												<UML:TaggedValue tag="author" value="OGC/CGI GeoSciML SWG"/>
												<UML:TaggedValue tag="complexity" value="1"/>
