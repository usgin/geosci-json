												<UML:TaggedValue tag="$ea_xref_property" value="$XREFPROP=$XID={067BF0A9-F86C-4a3a-867A-9D605BFA7E1A}$XID;$NAM=Stereotypes$NAM;$TYP=element property$TYP;$VIS=Public$VIS;$DES=@STEREO;Name=CodeList;GUID={3AB4660D-D6C5-4fff-BBEF-523A6AD80B4D};FQName=ISO 19100::CodeList;@ENDSTEREO;$DES;$CLT={3148A980-5324-4b6e-A242-7155AA1D37F7}$CLT;$ENDXREF;"/>
