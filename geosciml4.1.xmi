														<UML:TaggedValue tag="$ea_xref_property" value="$XREFPROP=$XID={92363E02-1A38-48c4-B670-A2C24B2FFF4F}$XID;$NAM=Stereotypes$NAM;$TYP=attribute property$TYP;$VIS=Public$VIS;$PAR=0$PAR;$DES=@STEREO;Name=property;GUID={CA8D4A96-E95D-4269-A091-5AB45ED3A99A};@ENDSTEREO;$DES;$CLT={221F4404-5D8E-4171-8381-B533BEC7A426}$CLT;$SUP=&lt;none&gt;$SUP;$ENDXREF;$XREFPROP=$XID={FEF13EC9-E557-45c8-BF8A-CA412EBA5C9C}$XID;$NAM=CustomProperties$NAM;$TYP=attribute property$TYP;$VIS=Public$VIS;$PAR=0$PAR;$DES=@PROP=@NAME=isID@ENDNAME;@TYPE=Boolean@ENDTYPE;@VALU=0@ENDVALU;@PRMT=@ENDPRMT;@ENDPROP;$DES;$CLT={221F4404-5D8E-4171-8381-B533BEC7A426}$CLT;$SUP=&lt;none&gt;$SUP;$ENDXREF;"/>
