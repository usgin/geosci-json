												<UML:Class name="GSML_GeometricDescriptionValue" xmi.id="EAID_3984A24A_BE4B_45be_838C_7F640CC5FF3F" visibility="public" namespace="EAPK_62318703_ED17_4e6e_8328_9831DBFE0A02" isRoot="false" isLeaf="false" isAbstract="true" isActive="false">
													<UML:ModelElement.stereotype>
														<UML:Stereotype name="DataType"/>
													</UML:ModelElement.stereotype>
													<UML:ModelElement.taggedValue>
														<UML:TaggedValue tag="documentation" value="&lt;font color=&quot;#4f81bd&quot;&gt;GSML_GeometricDescriptionValue&lt;/font&gt; is a special abstract data type for descriptions of planar or linear orientations of a geologic feature.   Different subtypes allow specifying direction by direction vector (e.g. dip/dip direction), compass point (e.g.  NE), or description (e.g. &quot;toward fold hinge&quot;, &quot;below').&#xA;"/>
														<UML:TaggedValue tag="isSpecification" value="false"/>
														<UML:TaggedValue tag="ea_stype" value="Class"/>
