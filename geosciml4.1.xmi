															<UML:ModelElement.taggedValue>
																<UML:TaggedValue tag="description" value="The property &lt;font color=&quot;#4f81bd&quot;&gt;hingeLineOrientation:GSML_LinearOrientation&lt;/font&gt; reports the specification of the hinge line orientation for fold. &lt;font color=&quot;#4f81bd&quot;&gt;GSML_LinearOrientation&lt;/font&gt; allows for a term value specification or a numeric specification of either or both the trend and plunge of hinge line.  Hinge plunge term examples: sub-vertical, steeply plunging, sub-horizontal, reclined and vertical for special cases in which hinge plunge is close to axial surface dip. 0..* cardinality allows for both a numeric specification and a term specification.&#xA;"/>
																<UML:TaggedValue tag="type" value="GSML_LinearOrientation"/>
																<UML:TaggedValue tag="derived" value="0"/>
																<UML:TaggedValue tag="containment" value="Not Specified"/>
