												<UML:TaggedValue tag="style" value="BackColor=8454143;BorderColor=-1;BorderWidth=1;FontColor=-1;VSwimLanes=1;HSwimLanes=1;BorderStyle=0;"/>
												<UML:TaggedValue tag="$ea_xref_property" value="$XREFPROP=$XID={1872B50B-A88E-44fc-B959-5845ED829359}$XID;$NAM=Stereotypes$NAM;$TYP=element property$TYP;$VIS=Public$VIS;$PAR=0$PAR;$DES=@STEREO;Name=dataType;GUID={D2C2581A-AA66-48f7-A7F2-95C6C7FB5751};FQName=UML Profile for INSPIRE data specifications::dataType;@ENDSTEREO;$DES;$CLT={DD9713AD-C742-4e77-9937-E79AF8E3F761}$CLT;$SUP=&lt;none&gt;$SUP;$ENDXREF;$XREFPROP=$XID={1733CD57-E2D0-442f-916A-410B6E371382}$XID;$NAM=CustomProperties$NAM;$TYP=element property$TYP;$VIS=Public$VIS;$DES=@PROP=@NAME=isActive@ENDNAME;@TYPE=Boolean@ENDTYPE;@VALU=@ENDVALU;@PRMT=@ENDPRMT;@ENDPROP;$DES;$CLT={DD9713AD-C742-4e77-9937-E79AF8E3F761}$CLT;$ENDXREF;"/>
