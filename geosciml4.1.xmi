													</UML:Association.connection>
												</UML:Association>
												<UML:Class name="GeomorphologicFeature" xmi.id="EAID_AAA9095D_703D_41d2_92A7_40FC3C656E5F" visibility="public" namespace="EAPK_810675D1_4288_48e9_A86E_35942BB6DF2B" isRoot="false" isLeaf="false" isAbstract="true" isActive="false">
													<UML:ModelElement.stereotype>
														<UML:Stereotype name="FeatureType"/>
													</UML:ModelElement.stereotype>
													<UML:ModelElement.taggedValue>
														<UML:TaggedValue tag="documentation" value="A geomorphologic feature is a kind of &lt;font color=&quot;#4f81bd&quot;&gt;GeologicFeature&lt;/font&gt; describing the shape and nature of the Earth's land surface. These landforms may be created by natural Earth processes (e.g., river channel, beach, moraine or mountain) or through human (anthropogenic) activity (e.g., dredged channel, reclaimed land, mine waste dumps).  In GeoSciML, the geomorphologic feature is modelled as a feature related (through &lt;font color=&quot;#4f81bd&quot;&gt;unitDescription&lt;/font&gt; property) to a &lt;font color=&quot;#4f81bd&quot;&gt;GeologicUnit&lt;/font&gt; that composes the form.&#xA;"/>
														<UML:TaggedValue tag="isSpecification" value="false"/>
														<UML:TaggedValue tag="ea_stype" value="Class"/>
														<UML:TaggedValue tag="ea_ntype" value="0"/>
