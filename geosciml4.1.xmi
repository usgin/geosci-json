														<UML:TaggedValue tag="$ea_xref_property" value="$XREFPROP=$XID={3B5CE169-1C04-4c5c-BBCD-E6BF82E7E597}$XID;$NAM=Stereotypes$NAM;$TYP=element property$TYP;$VIS=Public$VIS;$DES=@STEREO;Name=Type;GUID={79CE4004-F2AF-49e6-BE9D-298429D1B68A};FQName=ISO 19100::Type;@ENDSTEREO;$DES;$CLT={D2385579-8CEC-41fc-ACD0-1242C0AEF96E}$CLT;$ENDXREF;$XREFPROP=$XID={488341D5-EAA6-42b7-A26E-C188911F6652}$XID;$NAM=CustomProperties$NAM;$TYP=element property$TYP;$VIS=Public$VIS;$DES=@PROP=@NAME=isActive@ENDNAME;@TYPE=Boolean@ENDTYPE;@VALU=@ENDVALU;@PRMT=@ENDPRMT;@ENDPROP;$DES;$CLT={D2385579-8CEC-41fc-ACD0-1242C0AEF96E}$CLT;$ENDXREF;"/>
													</UML:ModelElement.taggedValue>
													<UML:Classifier.feature>
														<UML:Attribute name="role" changeable="none" visibility="public" ownerScope="instance" targetScope="instance">
															<UML:Attribute.initialValue>
																<UML:Expression/>
