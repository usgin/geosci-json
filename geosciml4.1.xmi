												<UML:Class name="GeologicSpecimenPreparation" xmi.id="EAID_99DC7785_B09A_4ea4_AE4E_BDEDC4CCA382" visibility="public" namespace="EAPK_23107128_C0E4_4f44_BA19_7C0926853370" isRoot="false" isLeaf="false" isAbstract="false" isActive="false">
