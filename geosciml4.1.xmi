													</UML:ModelElement.stereotype>
													<UML:ModelElement.taggedValue>
														<UML:TaggedValue tag="description" value="The &lt;font color=&quot;#4f81bd&quot;&gt;operator&lt;/font&gt; property is an association between a &lt;font color=&quot;#4f81bd&quot;&gt;BoreholeDetails&lt;/font&gt; and a &lt;font color=&quot;#4f81bd&quot;&gt;CIT:CI_ResponsibleParty&lt;/font&gt; describing the organisation responsible for commissioning the borehole (as opposed to actually drilling the borehole).&#xA;"/>
