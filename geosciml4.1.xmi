										</UML:Class>
										<UML:Class name="BoreholeDrillingMethodCode" xmi.id="EAID_4440BB61_EFD7_4179_B229_A12E84E99393" visibility="public" namespace="EAPK_93D78B7F_AC42_4588_B336_E5752E78AE36" isRoot="false" isLeaf="false" isAbstract="false" isActive="false">
