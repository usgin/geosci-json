																<UML:TaggedValue tag="scale" value="0"/>
																<UML:TaggedValue tag="static" value="0"/>
																<UML:TaggedValue tag="stereotype" value="estimatedProperty"/>
																<UML:TaggedValue tag="collection" value="false"/>
																<UML:TaggedValue tag="position" value="0"/>
																<UML:TaggedValue tag="lowerBound" value="0"/>
																<UML:TaggedValue tag="upperBound" value="1"/>
																<UML:TaggedValue tag="duplicates" value="0"/>
																<UML:TaggedValue tag="ea_guid" value="{CE58381D-F747-4812-83C3-00C6282DB05A}"/>
																<UML:TaggedValue tag="ea_localid" value="1562"/>
																<UML:TaggedValue tag="styleex" value="volatile=0;IsLiteral=0;"/>
