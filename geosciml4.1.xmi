														<UML:TaggedValue tag="$ea_xref_property" value="$XREFPROP=$XID={8072FE8C-F8EA-4f94-86D1-327FD280FFBA}$XID;$NAM=Stereotypes$NAM;$TYP=element property$TYP;$VIS=Public$VIS;$DES=@STEREO;Name=DataType;GUID={E95A6959-3B97-4470-B0EA-D5170B954446};FQName=ISO 19100::DataType;@ENDSTEREO;$DES;$CLT={3984A24A-BE4B-45be-838C-7F640CC5FF3F}$CLT;$ENDXREF;$XREFPROP=$XID={69BE4AB5-4C13-4737-8379-0076CFB3DD61}$XID;$NAM=CustomProperties$NAM;$TYP=element property$TYP;$VIS=Public$VIS;$DES=@PROP=@NAME=isActive@ENDNAME;@TYPE=Boolean@ENDTYPE;@VALU=@ENDVALU;@PRMT=@ENDPRMT;@ENDPROP;$DES;$CLT={3984A24A-BE4B-45be-838C-7F640CC5FF3F}$CLT;$ENDXREF;"/>
