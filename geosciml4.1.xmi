												<UML:Class name="RockMaterial" xmi.id="EAID_69643EA7_2142_46b5_9F91_BA2962E773C2" visibility="public" namespace="EAPK_EB2911AC_E2EF_4ba2_9E72_194A9661D815" isRoot="false" isLeaf="false" isAbstract="false" isActive="false">
