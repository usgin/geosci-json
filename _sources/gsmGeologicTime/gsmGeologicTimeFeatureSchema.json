{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.usgin.org/geosci-json/gsmGeologicTime/gsmGeologicTimeFeatureSchema.json",
  "description": "Single-Feature dispatcher for the gsmGeologicTime BB. Routes by the instance's `featureType` value to the matching $anchor in gsmGeologicTimeSchema.json. Recognised featureType values: GlobalStratotypePoint, GlobalStratotypeSection, StratigraphicPoint, StratigraphicSection.",
  "allOf": [
    {
      "if": {
        "required": [
          "featureType"
        ],
        "properties": {
          "featureType": {
            "const": "GlobalStratotypePoint"
          }
        }
      },
      "then": {
        "$ref": "gsmGeologicTimeSchema.json#GlobalStratotypePoint"
      }
    },
    {
      "if": {
        "required": [
          "featureType"
        ],
        "properties": {
          "featureType": {
            "const": "GlobalStratotypeSection"
          }
        }
      },
      "then": {
        "$ref": "gsmGeologicTimeSchema.json#GlobalStratotypeSection"
      }
    },
    {
      "if": {
        "required": [
          "featureType"
        ],
        "properties": {
          "featureType": {
            "const": "StratigraphicPoint"
          }
        }
      },
      "then": {
        "$ref": "gsmGeologicTimeSchema.json#StratigraphicPoint"
      }
    },
    {
      "if": {
        "required": [
          "featureType"
        ],
        "properties": {
          "featureType": {
            "const": "StratigraphicSection"
          }
        }
      },
      "then": {
        "$ref": "gsmGeologicTimeSchema.json#StratigraphicSection"
      }
    },
    {
      "if": {
        "not": {
          "required": [
            "featureType"
          ],
          "properties": {
            "featureType": {
              "enum": [
                "GlobalStratotypePoint",
                "GlobalStratotypeSection",
                "StratigraphicPoint",
                "StratigraphicSection"
              ]
            }
          }
        }
      },
      "then": false
    }
  ]
}
