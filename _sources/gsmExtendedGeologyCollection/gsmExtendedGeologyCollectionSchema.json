{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.usgin.org/geosci-json/gsmExtendedGeologyCollection/gsmExtendedGeologyCollectionSchema.json",
  "description": "Extended-profile FeatureCollection. Accepts the full set of 9 Basic\nfeatureType values (AnthropogenicGeomorphologicFeature, Contact, Fold,\nFoliation, GeologicEvent, GeologicUnit, MappedFeature,\nNaturalGeomorphologicFeature, ShearDisplacementStructure). Each\nFeature additionally requires its description slot(s) to be concrete\nExtension classes where one exists; FTs without an extension\ndescription slot (Anthropogenic / NaturalGeomorphologicFeature,\nMappedFeature) are pass-through.",
  "allOf": [
    {
      "$ref": "https://schemas.opengis.net/json-fg/featurecollection.json"
    },
    {
      "type": "object",
      "properties": {
        "features": {
          "type": "array",
          "items": {
            "allOf": [
              {
                "if": {
                  "required": [
                    "featureType"
                  ],
                  "properties": {
                    "featureType": {
                      "const": "AnthropogenicGeomorphologicFeature"
                    }
                  }
                },
                "then": {
                  "$ref": "../gsmBasicGeology/gsmBasicGeologySchema.json#AnthropogenicGeomorphologicFeature"
                }
              },
              {
                "if": {
                  "required": [
                    "featureType"
                  ],
                  "properties": {
                    "featureType": {
                      "const": "Contact"
                    }
                  }
                },
                "then": {
                  "allOf": [
                    {
                      "$ref": "../gsmBasicGeology/gsmBasicGeologySchema.json#Contact"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "properties": {
                          "type": "object",
                          "properties": {
                            "stContactDescription": {
                              "$ref": "../gsmGeologicStructureExtension/gsmGeologicStructureExtensionSchema.json#ContactDescription"
                            }
                          }
                        }
                      }
                    }
                  ]
                }
              },
              {
                "if": {
                  "required": [
                    "featureType"
                  ],
                  "properties": {
                    "featureType": {
                      "const": "Fold"
                    }
                  }
                },
                "then": {
                  "allOf": [
                    {
                      "$ref": "../gsmBasicGeology/gsmBasicGeologySchema.json#Fold"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "properties": {
                          "type": "object",
                          "properties": {
                            "stFoldDescription": {
                              "$ref": "../gsmGeologicStructureExtension/gsmGeologicStructureExtensionSchema.json#FoldDescription"
                            }
                          }
                        }
                      }
                    }
                  ]
                }
              },
              {
                "if": {
                  "required": [
                    "featureType"
                  ],
                  "properties": {
                    "featureType": {
                      "const": "Foliation"
                    }
                  }
                },
                "then": {
                  "allOf": [
                    {
                      "$ref": "../gsmBasicGeology/gsmBasicGeologySchema.json#Foliation"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "properties": {
                          "type": "object",
                          "properties": {
                            "stFoliationDescription": {
                              "$ref": "../gsmGeologicStructureExtension/gsmGeologicStructureExtensionSchema.json#FoliationDescription"
                            }
                          }
                        }
                      }
                    }
                  ]
                }
              },
              {
                "if": {
                  "required": [
                    "featureType"
                  ],
                  "properties": {
                    "featureType": {
                      "const": "GeologicEvent"
                    }
                  }
                },
                "then": {
                  "allOf": [
                    {
                      "$ref": "../gsmBasicGeology/gsmBasicGeologySchema.json#GeologicEvent"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "properties": {
                          "type": "object",
                          "properties": {
                            "gaEventDescription": {
                              "type": "array",
                              "items": {
                                "$ref": "../gsmGeologicTime/gsmGeologicTimeSchema.json#GeologicEventDescription"
                              }
                            }
                          }
                        }
                      }
                    }
                  ]
                }
              },
              {
                "if": {
                  "required": [
                    "featureType"
                  ],
                  "properties": {
                    "featureType": {
                      "const": "GeologicUnit"
                    }
                  }
                },
                "then": {
                  "allOf": [
                    {
                      "$ref": "../gsmBasicGeology/gsmBasicGeologySchema.json#GeologicUnit"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "properties": {
                          "type": "object",
                          "properties": {
                            "gbUnitDescription": {
                              "type": "array",
                              "items": {
                                "$ref": "../gsmGeologicUnitExtension/gsmGeologicUnitExtensionSchema.json#GeologicUnitDescription"
                              }
                            },
                            "gbMaterialDescription": {
                              "type": "array",
                              "items": {
                                "$ref": "../gsmEarthMaterial/gsmEarthMaterialSchema.json#CompoundMaterialDescription"
                              }
                            }
                          }
                        }
                      }
                    }
                  ]
                }
              },
              {
                "if": {
                  "required": [
                    "featureType"
                  ],
                  "properties": {
                    "featureType": {
                      "const": "MappedFeature"
                    }
                  }
                },
                "then": {
                  "$ref": "../gsmBasicGeology/gsmBasicGeologySchema.json#MappedFeature"
                }
              },
              {
                "if": {
                  "required": [
                    "featureType"
                  ],
                  "properties": {
                    "featureType": {
                      "const": "NaturalGeomorphologicFeature"
                    }
                  }
                },
                "then": {
                  "$ref": "../gsmBasicGeology/gsmBasicGeologySchema.json#NaturalGeomorphologicFeature"
                }
              },
              {
                "if": {
                  "required": [
                    "featureType"
                  ],
                  "properties": {
                    "featureType": {
                      "const": "ShearDisplacementStructure"
                    }
                  }
                },
                "then": {
                  "allOf": [
                    {
                      "$ref": "../gsmBasicGeology/gsmBasicGeologySchema.json#ShearDisplacementStructure"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "properties": {
                          "type": "object",
                          "properties": {
                            "stStructureDescription": {
                              "type": "array",
                              "items": {
                                "$ref": "../gsmGeologicStructureExtension/gsmGeologicStructureExtensionSchema.json#ShearDisplacementStructureDescription"
                              }
                            }
                          }
                        }
                      }
                    }
                  ]
                }
              },
              {
                "if": {
                  "not": {
                    "required": [
                      "featureType"
                    ],
                    "properties": {
                      "featureType": {
                        "enum": [
                          "AnthropogenicGeomorphologicFeature",
                          "Contact",
                          "Fold",
                          "Foliation",
                          "GeologicEvent",
                          "GeologicUnit",
                          "MappedFeature",
                          "NaturalGeomorphologicFeature",
                          "ShearDisplacementStructure"
                        ]
                      }
                    }
                  }
                },
                "then": false
              }
            ]
          }
        }
      }
    }
  ]
}
