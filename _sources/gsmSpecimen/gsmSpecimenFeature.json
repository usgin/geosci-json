{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.usgin.org/geosci-json/gsmSpecimen/gsmSpecimenFeature.json",
  "description": "Single-Feature dispatcher for the gsmSpecimen BB. Routes by the instance's `featureType` value to the matching $anchor in gsmSpecimen.json. Recognised featureType values: AnalyticalInstrument, AnalyticalProcess, AnalyticalSession, GeochronologicInterpretation, GeologicSamplingMethod, Image, ReferenceSpecimen.",
  "allOf": [
    {
      "if": {
        "required": [
          "featureType"
        ],
        "properties": {
          "featureType": {
            "const": "AnalyticalInstrument"
          }
        }
      },
      "then": {
        "$ref": "gsmSpecimen.json#AnalyticalInstrument"
      }
    },
    {
      "if": {
        "required": [
          "featureType"
        ],
        "properties": {
          "featureType": {
            "const": "AnalyticalProcess"
          }
        }
      },
      "then": {
        "$ref": "gsmSpecimen.json#AnalyticalProcess"
      }
    },
    {
      "if": {
        "required": [
          "featureType"
        ],
        "properties": {
          "featureType": {
            "const": "AnalyticalSession"
          }
        }
      },
      "then": {
        "$ref": "gsmSpecimen.json#AnalyticalSession"
      }
    },
    {
      "if": {
        "required": [
          "featureType"
        ],
        "properties": {
          "featureType": {
            "const": "GeochronologicInterpretation"
          }
        }
      },
      "then": {
        "$ref": "gsmSpecimen.json#GeochronologicInterpretation"
      }
    },
    {
      "if": {
        "required": [
          "featureType"
        ],
        "properties": {
          "featureType": {
            "const": "GeologicSamplingMethod"
          }
        }
      },
      "then": {
        "$ref": "gsmSpecimen.json#GeologicSamplingMethod"
      }
    },
    {
      "if": {
        "required": [
          "featureType"
        ],
        "properties": {
          "featureType": {
            "const": "Image"
          }
        }
      },
      "then": {
        "$ref": "gsmSpecimen.json#Image"
      }
    },
    {
      "if": {
        "required": [
          "featureType"
        ],
        "properties": {
          "featureType": {
            "const": "ReferenceSpecimen"
          }
        }
      },
      "then": {
        "$ref": "gsmSpecimen.json#ReferenceSpecimen"
      }
    },
    {
      "if": {
        "not": {
          "required": [
            "featureType"
          ],
          "properties": {
            "featureType": {
              "enum": [
                "AnalyticalInstrument",
                "AnalyticalProcess",
                "AnalyticalSession",
                "GeochronologicInterpretation",
                "GeologicSamplingMethod",
                "Image",
                "ReferenceSpecimen"
              ]
            }
          }
        }
      },
      "then": false
    }
  ]
}
