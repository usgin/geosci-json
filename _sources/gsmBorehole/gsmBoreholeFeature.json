{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.usgin.org/geosci-json/gsmBorehole/gsmBoreholeFeature.json",
  "description": "Single-Feature dispatcher for the gsmBorehole BB. Routes by the instance's `featureType` value to the matching $anchor in gsmBorehole.json. Recognised featureType values: Borehole, BoreholeInterval, OriginPosition.",
  "allOf": [
    {
      "if": {
        "required": [
          "featureType"
        ],
        "properties": {
          "featureType": {
            "const": "Borehole"
          }
        }
      },
      "then": {
        "$ref": "gsmBorehole.json#Borehole"
      }
    },
    {
      "if": {
        "required": [
          "featureType"
        ],
        "properties": {
          "featureType": {
            "const": "BoreholeInterval"
          }
        }
      },
      "then": {
        "$ref": "gsmBorehole.json#BoreholeInterval"
      }
    },
    {
      "if": {
        "required": [
          "featureType"
        ],
        "properties": {
          "featureType": {
            "const": "OriginPosition"
          }
        }
      },
      "then": {
        "$ref": "gsmBorehole.json#OriginPosition"
      }
    },
    {
      "if": {
        "not": {
          "required": [
            "featureType"
          ],
          "properties": {
            "featureType": {
              "enum": [
                "Borehole",
                "BoreholeInterval",
                "OriginPosition"
              ]
            }
          }
        }
      },
      "then": false
    }
  ]
}
