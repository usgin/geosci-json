{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.usgin.org/geosci-json/gsmGeologicStructureExtension/gsmGeologicStructureExtensionFeature.json",
  "description": "Single-Feature dispatcher for the gsmGeologicStructureExtension BB. Routes by the instance's `featureType` value to the matching $anchor in gsmGeologicStructureExtension.json. Recognised featureType values: DisplacementEvent, FoldSystem, Joint, Layering, Lineation, NonDirectionalStructure.",
  "allOf": [
    {
      "if": {
        "required": [
          "featureType"
        ],
        "properties": {
          "featureType": {
            "const": "DisplacementEvent"
          }
        }
      },
      "then": {
        "$ref": "gsmGeologicStructureExtension.json#DisplacementEvent"
      }
    },
    {
      "if": {
        "required": [
          "featureType"
        ],
        "properties": {
          "featureType": {
            "const": "FoldSystem"
          }
        }
      },
      "then": {
        "$ref": "gsmGeologicStructureExtension.json#FoldSystem"
      }
    },
    {
      "if": {
        "required": [
          "featureType"
        ],
        "properties": {
          "featureType": {
            "const": "Joint"
          }
        }
      },
      "then": {
        "$ref": "gsmGeologicStructureExtension.json#Joint"
      }
    },
    {
      "if": {
        "required": [
          "featureType"
        ],
        "properties": {
          "featureType": {
            "const": "Layering"
          }
        }
      },
      "then": {
        "$ref": "gsmGeologicStructureExtension.json#Layering"
      }
    },
    {
      "if": {
        "required": [
          "featureType"
        ],
        "properties": {
          "featureType": {
            "const": "Lineation"
          }
        }
      },
      "then": {
        "$ref": "gsmGeologicStructureExtension.json#Lineation"
      }
    },
    {
      "if": {
        "required": [
          "featureType"
        ],
        "properties": {
          "featureType": {
            "const": "NonDirectionalStructure"
          }
        }
      },
      "then": {
        "$ref": "gsmGeologicStructureExtension.json#NonDirectionalStructure"
      }
    },
    {
      "if": {
        "not": {
          "required": [
            "featureType"
          ],
          "properties": {
            "featureType": {
              "enum": [
                "DisplacementEvent",
                "FoldSystem",
                "Joint",
                "Layering",
                "Lineation",
                "NonDirectionalStructure"
              ]
            }
          }
        }
      },
      "then": false
    }
  ]
}
